<%- include('partials/header') %>

  <div class="container">
    <div class="card">
      <h1>Welcome Back</h1>
      <p>Sign in to manage bookings, billing, and reports.</p>

      <form id="loginForm" onsubmit="return false;">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required />

        <label for="password">Password</label>
        <input type="password" id="password" name="password" required />

        <button type="submit">Login</button>
      </form>

      <p>
        New guest? <a href="/views/register.html">Create an account</a>
      </p>
    </div>

    
  </div>

  <%- include('partials/footer') %>
  <script src="/public/js/app.js"></script>
  <script>
    const form = document.getElementById('loginForm');
    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      const email = form.email.value.trim();
      const password = form.password.value.trim();

      try {
        const { data } = await window.app.apiRequest('/api/auth/login', {
          method: 'POST',
          body: JSON.stringify({ email, password }),
        });

        switch (data.role) {
          case 'Manager':
            window.location.href = '/views/manager-dashboard.html';
            break;
          case 'Receptionist':
            window.location.href = '/views/receptionist-dashboard.html';
            break;
          default:
            window.location.href = '/views/guest-dashboard.html';
        }
      } catch (err) {
        window.app.handleError(err);
      }
    });
  </script>
</body>
</html>
