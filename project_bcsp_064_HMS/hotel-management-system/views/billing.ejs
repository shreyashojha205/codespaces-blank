<%- include('partials/header') %>

  <div class="container">
    <div class="card">
      <h1>Billing Calculator</h1>
      <p>Provide a booking ID to see the latest bill (room + services + tax).</p>

      <form id="billingForm">
        <label for="bookingId">Booking ID</label>
        <input type="number" id="bookingId" name="bookingId" required />

        <button type="submit">Calculate</button>
      </form>

      <div id="billingResult"></div>
    </div>

    
  </div>

  <%- include('partials/footer') %>
  <script src="/public/js/app.js"></script>
  <script>
    const form = document.getElementById('billingForm');
    const resultEl = document.getElementById('billingResult');

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      const bookingId = form.bookingId.value;

      try {
        const { data } = await window.app.apiRequest(`/api/billing/${bookingId}`);

        resultEl.innerHTML = `
          <div class="card card--transparent">
            <h2>Billing Summary</h2>
            <p><strong>Nights:</strong> ${data.booking.nights}</p>
            <p><strong>Room Charges:</strong> ₹${data.booking.roomCharges.toFixed(2)}</p>
            <p><strong>Service Charges:</strong> ₹${data.booking.serviceCharges.toFixed(2)}</p>
            <p><strong>Tax (18%):</strong> ₹${data.booking.tax.toFixed(2)}</p>
            <p><strong>Total Amount:</strong> ₹${data.booking.totalAmount.toFixed(2)}</p>
            <pre>${JSON.stringify(data.bill, null, 2)}</pre>
          </div>
        `;
      } catch (err) {
        window.app.handleError(err);
      }
    });
  </script>
</body>
</html>
